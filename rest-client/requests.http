GET {{URL_API}}/authors
Content-Type: application/json

### READ Author
# @name readAuthor
GET {{URL_API}}/authors/{{AUTHOR_ID}}
Content-Type: application/json

### UPDATE Author
# @name updateAuthor
PATCH {{URL_API}}/authors/{{AUTHOR_ID}}
Content-Type: application/json

{
  "name": "Rifujin na Magonote"
}

### DELETE Author
# @name deleteAuthor
DELETE {{URL_API}}/authors/{{AUTHOR_ID}}
Content-Type: application/json

#### Illustrator ENDPOINTS

### CREATE Illustrator
# @name createIllustrator
POST {{URL_API}}/illustrators
