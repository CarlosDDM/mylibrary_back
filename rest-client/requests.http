@URL_API=http://localhost:3000
@SERIE_ID=0f885288-a676-49e3-9278-0e0ced086485
@FRANCHISE_ID={{createFranchise.response.body.id}}

@AUTHOR_ID={{createAuthor.response.body.id}}

@ILLUSTRATOR_ID={{createIllustrator.response.body.id}}

### GET all Options
GET {{URL_API}}/options
Content-Type: application/json

#### Serie ENDPOINTS

### CREATE Serie
# @name createSerie
POST {{URL_API}}/series
Content-Type: application/json

{
  "name": "The Eminence in Shadow",
  "statusId": "97b1a54d-eea0-4f1b-9a98-559d63525609",
  "serieVolumes": 8
}

### GET ALL Series
# @name readAllSerie
GET {{URL_API}}/series
Content-Type: application/json

### GET Serie
# @name readSerie
GET {{URL_API}}/series/{{SERIE_ID}}
Content-Type: application/json

### UPDATE Serie
# @name updateSerie
PATCH  {{URL_API}}/series/{{SERIE_ID}}
Content-Type: application/json

{
  "name": "No Game No Life",
  "statusId": "5898aed2-65b2-472a-b646-4c97f7e4c6a1",
  "franchiseId":"a8697b40-f930-41b4-8373-e397c83e457e",
  "serieVolumes": 13
}

### DELETE Serie
# @name deleteSeries
DELETE {{URL_API}}/series/{{SERIE_ID}}
Content-Type: application/json

#### Franchise ENDPOINTS

### CREATE Franchise
# @name createFranchise
POST {{URL_API}}/franchises
Content-Type: application/json

{
  "name": "No Game No Life 2"
}

### READ ALL Franchise
# @name readAllFranchise
GET {{URL_API}}/franchises
Content-Type: application/json

### READ Franchise
# @name readFranchise
GET {{URL_API}}/franchises/{{FRANCHISE_ID}}
Content-Type: application/json

### UPDATE Franchise
# @name updateFranchise
PATCH {{URL_API}}/franchises/{{FRANCHISE_ID}}
Content-Type: application/json

{
  "name": "No Game No Life 1"
}

### DELETE Franchise
# @name deleteFranchise
DELETE {{URL_API}}/franchises/{{FRANCHISE_ID}}
Content-Type: application/json

#### Works ENDPOINTS

### CREATE Work
# @name createWork
POST {{URL_API}}/works
Content-Type: application/json

{
  "name": "The Eminence in Shadow",
  "subtitle": "",
  "volume": 1,
  //"price": "",
  "mediaId": "0ffa3376-e909-4520-bb0b-6007d813a597",
  "languageId": "1ef9ba72-4449-437d-a768-5e0bf9ced2f9",
  "serieId": "37b14819-5482-4a9f-8feb-7104c283fc70",
  "isSpecialEdition": false
}

### READ All Work
# @name readAllWork
GET {{URL_API}}/works
Content-Type: application/json


#### Authors ENDPOINTS
### CREATE Author
